# Copy to .env: cp .env.example .env
#
# MONGODB_URI must be copied from Atlas: Cluster -> Connect -> Drivers -> Python.
# The hostname is something like: myapp.abc123.mongodb.net
# NEVER use the literal substring "<cluster>" — DNS will fail with NXDOMAIN.

# For local Docker MongoDB (see LOCAL_MONGO_SETUP.md):
MONGODB_URI=mongodb://localhost:27017/clearview_db
# For Atlas, replace with your connection string:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=clearview_db
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com

GEMINI_MODEL=gemini-2.5-flash
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VERA_VOICE_ID=
ELEVENLABS_PHONE_NUMBER_ID=
STRIPE_SECRET_KEY=
STRIPE_CARDHOLDER_ID=
FRONTEND_URL=https://grizz-hacks-8.vercel.app
# Optional: *additional* CORS origins (comma-separated). These merge with built-in defaults
# (production Vercel, localhost, FRONTEND_URL) — they do not replace them.
# CORS_ORIGINS=https://my-custom-domain.com
# *.vercel.app previews are also allowed via CORS_ORIGIN_REGEX in config.py by default.

# Vera agentic fraud detection
USER_PHONE_NUMBER=+1XXXXXXXXXX
FRAUD_AMOUNT_THRESHOLD=200.0
FRAUD_OUTBOUND_USE_FIRST_MESSAGE=true
# ngrok public URL so ElevenLabs can call back to approve/deny (e.g. https://xxxx.ngrok-free.app)
BACKEND_PUBLIC_URL=
JWT_SECRET_KEY=change-me-generate-with-python-secrets-token_hex-32
